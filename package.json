{
  "name": "vault-relay",
  "version": "0.16.0",
  "description": "Turn Markdown notes into drafts for X, Zhihu, WeChat, and Xiaohongshu.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "test": "tsx --test tests/*.test.ts",
    "test:companion": "node tests/companion-smoke.mjs",
    "test:queue": "node tests/queue-smoke.mjs",
    "verify": "npm test && npm run build && npm run test:companion && npm run test:queue",
    "license:generate": "node scripts/generate-license.mjs",
    "license:from-purchase": "node scripts/generate-pro-code-from-purchase.mjs",
    "record:promo": "node promo/record-demo.mjs"
  },
  "keywords": [
    "obsidian",
    "markdown",
    "publisher",
    "local-first"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.15.3",
    "esbuild": "^0.25.3",
    "ffmpeg-static": "^5.3.0",
    "obsidian": "^1.8.7",
    "puppeteer-core": "^25.1.0",
    "tslib": "^2.8.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "html-to-image": "^1.11.13",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-frontmatter": "^2.0.1",
    "mdast-util-gfm": "^3.1.0",
    "micromark-extension-frontmatter": "^2.0.0",
    "micromark-extension-gfm": "^3.0.0"
  }
}
