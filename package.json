{
  "name": "vault-relay",
  "version": "0.7.0",
  "description": "Turn long-form notes into publish-ready content without moving your vault.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "test": "tsx --test tests/*.test.ts",
    "record:promo": "node promo/record-demo.mjs"
  },
  "keywords": [
    "obsidian",
    "markdown",
    "publisher",
    "local-first"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.15.3",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.25.3",
    "ffmpeg-static": "^5.3.0",
    "obsidian": "^1.8.7",
    "puppeteer-core": "^25.1.0",
    "tslib": "^2.8.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "html-to-image": "^1.11.13",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-frontmatter": "^2.0.1",
    "mdast-util-gfm": "^3.1.0",
    "micromark-extension-frontmatter": "^2.0.0",
    "micromark-extension-gfm": "^3.0.0"
  }
}
